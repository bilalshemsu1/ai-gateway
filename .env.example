# AI Gateway - Environment Variables
# Copy this file to .env and fill in your API keys

# Auth token (required for API access)
# Generate a random string and keep it secret
API_SECRET=

# Google Gemini (free: 60 req/min)
# Get key: https://ai.google.dev
GEMINI_API_KEY=

# Groq (free: 14,400 req/day)
# Get key: https://console.groq.com
GROQ_API_KEY=

# Mistral (free tier available)
# Get key: https://console.mistral.ai
MISTRAL_API_KEY=

# OpenRouter (multiple free models)
# Get key: https://openrouter.ai
OPENROUTER_API_KEY=

# OpenCodeZen
# Get key: https://opencode.ai
OPENCODE_API_KEY=

# ZYDIT
# Get key: https://zydit.in/
ZYDIT_API_KEY=

# Agnes AI
# Get key: https://apihub.agnes-ai.com
AGNES_API_KEY=

# Nvidia
# Get key: https://build.nvidia.com
NVIDIA_API_KEY=